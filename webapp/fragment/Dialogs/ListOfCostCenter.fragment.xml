<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<SelectDialog noDataText="{i18n>noCostCenterFound}" title="{i18n>listOfCostCenter}" search="onSearchF4Value" confirm="onAddChargeDetails"
		items="{ path: 'F4DropdownMRF>/CostCenterSet' }">
		<items>
			<StandardListItem title="{F4DropdownMRF>Kostl}" description="{F4DropdownMRF>Ltext}" type="Active"/>
		</items>
		<customData>
			<core:CustomData key="search_field" value="Kostl"/>
			<core:CustomData key="search_field_desc" value="Ltext"/>
			<core:CustomData key="search_field_filter" value="Plant"/>
			<core:CustomData key="control_field" value="Kostl"/>
			<core:CustomData key="control_field_desc" value="KostlDesc"/>
		</customData>
	</SelectDialog>
</core:FragmentDefinition>