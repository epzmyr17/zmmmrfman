<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<SelectDialog noDataText="{i18n>NoCityFound}" title="{i18n>listOfCity}" search="onSearchF4ValueFilter" confirm="onAddItemDialog"
		multiSelect="false" items="{ path: 'F4DropdownMRF>/CitySet' }">
		<items>
			<StandardListItem title="{F4DropdownMRF>CityDesc}" description="{F4DropdownMRF>ProvinceDesc}" type="Active"/>
		</items>
		<customData>
			<core:CustomData key="search_field" value="CityCode"/>
			<core:CustomData key="search_field_desc" value="CityDesc"/>
			<core:CustomData key="search_field_filter1" value="ProvinceCode"/>
			<core:CustomData key="control_field" value="CityCode"/>
			<core:CustomData key="control_field_desc" value="CityDesc"/>
		</customData>
	</SelectDialog>
</core:FragmentDefinition>