<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<SelectDialog noDataText="{i18n>noListofPlant}" title="{i18n>listOfPlant}" search="onSearchF4ValuePlant" confirm="onAddPlant" multiSelect="false"
		items="{ path: 'F4DropdownMRF>/I_Plant' }">
		<items>
			<StandardListItem title="{F4DropdownMRF>Plant}" description="{F4DropdownMRF>PlantName}" type="Active"/>
		</items>
		<customData>
			<core:CustomData key="search_field" value="Plant"/>
			<core:CustomData key="search_field_desc" value="PlantName"/>
		</customData>
	</SelectDialog>
</core:FragmentDefinition>