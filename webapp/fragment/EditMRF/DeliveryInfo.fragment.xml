<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:f="sap.ui.layout.form">
	<!-- Start of edit by MS223343 - PAL-2024-005 -->
	<f:SimpleForm id="idSimpleFormDeliveryInfo" editable="true" layout="ResponsiveGridLayout" labelSpanXL="6" labelSpanL="6" labelSpanM="12"
		labelSpanS="12" adjustLabelSpan="false" emptySpanXL="2" emptySpanL="2" emptySpanM="4" emptySpanS="0" columnsXL="2" columnsL="2" columnsM="1"
		singleContainerFullSize="false">
		<!-- End of edit by MS223343 - PAL-2024-005 -->
		<f:content>
			<Toolbar>
				<Title text="{i18n>deliveryDetails}" level="H5" titleStyle="H5"/>
			</Toolbar>
			<Label text="{i18n>modeOfDelivery}" required="true"/>
			<Select forceSelection="false" id="country" items="{F4DropdownMRF>/DeliveryModeSet}" selectedKey="{Delivmode}" change="onAddComboBoxDesc"
				enabled="{viewConfig>/editable}">
				<items>
					<core:Item text="{F4DropdownMRF>Delivmode}" key="{F4DropdownMRF>Id}"/>
				</items>
				<customData>
					<core:CustomData key="control_field_desc" value="DelivModeDesc"/>
				</customData>
			</Select>
			<Label text="{i18n>deliveryAdd}" required="true" visible="{=!${IsMultiple}}"/>
			<TextArea value="{ path : 'Delivaddress'}" change="onChangeFieldValue" visible="{=!${IsMultiple}}" placeholder="{i18n>enterAddress}"
				required="true" maxLength="{path:'/#MRFHeader/Delivaddress/@maxLength', formatter:'.formatter.fnGetMaxLength'}"
				enabled="{viewConfig>/editable}"/>
			<!--Start of edit - MS223343 - PAL-2022-004-->
			<Label text="{i18n>provinceDesc}" required="true"
				visible="{= !${IsMultiple} &amp;&amp; ${Delivmode} !== '' &amp;&amp; ${Delivmode} !== 'P' }"/>
			<Input value="{ path: 'ProvinceDesc' }" visible="{= !${IsMultiple} &amp;&amp; ${Delivmode} !== '' &amp;&amp; ${Delivmode} !== 'P' }"
				placeholder="{i18n>selectProvince}" required="true" change="onChangeFieldValue" enabled="{viewConfig>/editable}" valueHelpOnly="true"
				showValueHelp="true" valueHelpRequest="onOpenDialogFilter">
				<customData>
					<core:CustomData key="fragment_name" value="ListOfProvince"/>
					<core:CustomData key="variable_name" value="_oListOfProvince"/>
					<core:CustomData key="searchfield_maxlength" value="10"/>
				</customData>
			</Input>
			<Label text="{i18n>cityDesc}" required="true" visible="{= !${IsMultiple} &amp;&amp; ${Delivmode} !== '' &amp;&amp; ${Delivmode} !== 'P' }"/>
			<Input value="{ path: 'CityDesc' }" visible="{= !${IsMultiple} &amp;&amp; ${Delivmode} !== '' &amp;&amp; ${Delivmode} !== 'P' }"
				placeholder="{i18n>selectCity}" required="true" change="onChangeFieldValue" enabled="{viewConfig>/editable}" valueHelpOnly="true"
				showValueHelp="true" valueHelpRequest="onOpenDialogFilter">
				<customData>
					<core:CustomData key="fragment_name" value="ListOfCity"/>
					<core:CustomData key="variable_name" value="_oListOfCity"/>
					<core:CustomData key="searchfield_maxlength" value="10"/>
				</customData>
			</Input>
			<Label text="{i18n>barangayDesc}" required="true"
				visible="{= !${IsMultiple} &amp;&amp; ${Delivmode} !== '' &amp;&amp; ${Delivmode} !== 'P' }"/>
			<Input value="{ path: 'BarangayText' }" visible="{= !${IsMultiple} &amp;&amp; ${Delivmode} !== '' &amp;&amp; ${Delivmode} !== 'P' }"
				placeholder="{i18n>selectBarangay}" required="true" change="onChangeFieldValue" enabled="{viewConfig>/editable}" valueHelpOnly="true"
				showValueHelp="true" valueHelpRequest="onOpenDialogFilter">
				<customData>
					<core:CustomData key="fragment_name" value="ListOfBarangay"/>
					<core:CustomData key="variable_name" value="_oListOfBarangay"/>
					<core:CustomData key="searchfield_maxlength" value="10"/>
				</customData>
			</Input>
			<!--Start of edit - MS223343 - PAL-2022-004-->
			<Label text="{i18n>contactPerson}" required="true" visible="{=!${IsMultiple}}"/>
			<Input value="{ path: 'Contactperson'}" change="onChangeFieldValue" visible="{=!${IsMultiple}}" placeholder="{i18n>enterContactPerson}"
				required="true" maxLength="{path:'/#MRFHeader/Contactperson/@maxLength', formatter:'.formatter.fnGetMaxLength'}"
				enabled="{viewConfig>/editable}"/>
			<!-- Start of insert by MS223343 - PAL-2024-005 : New field 'Employee ID' -->
			<Label text="{i18n>employeeID}" required="false" visible="{=!${IsMultiple}}"/>
			<Input value="{ path: 'EmployeeIdNum'}" change="onChangeFieldValue" visible="{=!${IsMultiple}}" placeholder="{i18n>enterEmployeeId}"
				required="false" maxLength="{path:'/#MRFHeader/EmployeeIdNum/@maxLength', formatter:'.formatter.fnGetMaxLength'}"
				enabled="{viewConfig>/editable}"/>
			<!-- End of insert by MS223343 - PAL-2024-005 : New field 'Employee ID' -->
			<Label text="{i18n>contactNumber}" required="true" visible="{=!${IsMultiple}}"/>
			<Input value="{ path: 'Contactnumber'}" change="onChangeFieldValue" visible="{=!${IsMultiple}}" placeholder="{i18n>enterContactNum}"
				required="true" maxLength="{path:'/#MRFHeader/Contactnumber/@maxLength', formatter:'.formatter.fnGetMaxLength'}"
				enabled="{viewConfig>/editable}"/>
			<!-- New -->
			<Label text="{i18n>emailAddress}" required="true" visible="{=!${IsMultiple}}"/>
			<Input value="{ path: 'Email', type: '.types.emailType'}" change="onChangeFieldValue" visible="{=!${IsMultiple}}"
				placeholder="{i18n>enterEmailAddress}" required="true"
				maxLength="{path:'/#MRFHeader/Email/@maxLength', formatter:'.formatter.fnGetMaxLength'}" enabled="{viewConfig>/editable}"/>
			<!-- Alternate contact person -->
			<Label text="{i18n>alternateContact}" visible="{=!${IsMultiple}}"/>
			<Switch state="{OthContPerson}" visible="{=!${IsMultiple}}" change="onPressAlternateContact" enabled="{viewConfig>/editable}"/>
			<Label text="{i18n>alternateContactName}" required="false" visible="{=!${IsMultiple} &amp;&amp; ${OthContPerson}}"/>
			<Input value="{ path: 'OthContName' }" change="onChangeFieldValue" visible="{=!${IsMultiple} &amp;&amp; ${OthContPerson}}"
				placeholder="{i18n>enterAlternateContactName}" required="false"
				maxLength="{path:'/#MRFHeader/OthContName/@maxLength', formatter:'.formatter.fnGetMaxLength'}" enabled="{viewConfig>/editable}"/>
			<Label text="{i18n>alternateContactNumber}" required="false" visible="{=!${IsMultiple} &amp;&amp; ${OthContPerson}}"/>
			<Input value="{ path: 'OthContNumber'}" change="onChangeFieldValue" visible="{=!${IsMultiple} &amp;&amp; ${OthContPerson}}"
				placeholder="{i18n>enterAlternateContactNumber}" required="false"
				maxLength="{path:'/#MRFHeader/OthContNumber/@maxLength', formatter:'.formatter.fnGetMaxLength'}" enabled="{viewConfig>/editable}"/>
			<Label text="{i18n>alternateContactEmail}" required="false" visible="{=!${IsMultiple} &amp;&amp; ${OthContPerson}}"/>
			<Input id="idOtherEamil" value="{ path: 'OthEmail', type: '.types.emailType'}" change="onChangeFieldValue"
				visible="{=!${IsMultiple} &amp;&amp; ${OthContPerson}}" placeholder="{i18n>enterAlternateContactEmail}" required="false"
				maxLength="{path:'/#MRFHeader/OthEmail/@maxLength', formatter:'.formatter.fnGetMaxLength'}" enabled="{viewConfig>/editable}"/>
		</f:content>
	</f:SimpleForm>
</core:FragmentDefinition>