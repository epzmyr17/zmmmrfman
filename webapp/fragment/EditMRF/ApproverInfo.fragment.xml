<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<Table id="idApproverTable" inset="false" items="{ path: 'editMRF>/NavTo_MRFHeader_Approver'}" class="sapUiSmallMarginBottom">
		<headerToolbar>
			<OverflowToolbar>
				<Title text="{i18n>selectedApprover}" level="H3"/>
				<ToolbarSpacer/>
				<!-- Enabled only if 'edit request' is clicked and status id not equal to 09 / Returned -->
				<Button text="{i18n>addNextApv}" press="onAddApprovers" enabled="{=${viewConfig>/editable} &amp;&amp; ${StatusId} !== '09'}"
					icon="sap-icon://add"/>
				<!-- Enabled only if 'edit request' is clicked and status id not equal to 09 / Returned -->
				<Button text="{i18n>addFBAApv}" press="onAddFBAApprover" enabled="{=${viewConfig>/editable} &amp;&amp; ${StatusId} !== '09'}"
					icon="sap-icon://add-contact"/>
				<!-- Enabled only if 'edit request' is clicked and status id not equal to 09 / Returned -->
				<Button text="{i18n>additionalApv}" press="onAdditionalApprover" enabled="{=${viewConfig>/editable} &amp;&amp; ${StatusId} !== '09'}"
					icon="sap-icon://add-coursebook"/>
			</OverflowToolbar>
		</headerToolbar>
		<columns>
			<Column hAlign="Begin" width="1em" popinDisplay="Inline">
				<Text text="{i18n>sequence}"/>
			</Column>
			<Column hAlign="Begin" width="4em" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
				<Text text="{i18n>type}"/>
			</Column>
			<Column hAlign="Begin" width="5em" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
				<Text text="{i18n>emailAddress}"/>
			</Column>
			<Column hAlign="Begin" width="4em" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
				<Text text="{i18n>approverName}"/>
			</Column>
			<Column hAlign="Begin" width="2em" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
				<Text text="{i18n>userId}"/>
			</Column>
			<Column hAlign="Begin" width="2em" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline"
				visible="{=${StatusId} !== '01' &amp;&amp; ${StatusId} !== '11'}">
				<Text text="{i18n>status}"/>
			</Column>
			<Column hAlign="End" width="2em" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
				<Text text="{i18n>action}"/>
			</Column>
		</columns>
		<items>
			<ColumnListItem vAlign="Middle" type="Inactive">
				<cells>
					<ObjectIdentifier text="{editMRF>Zlevel}"/>
					<ObjectIdentifier text="{path: 'editMRF>Apvtype', formatter: '.formatter.formatApproverType'}"/>
					<!-- Enabled only if 'edit request' is clicked and status id not equal to 09 / Returned -->
					<Input value="{editMRF>Email}" placeholder="{i18n>selectEmailAddress}" showValueHelp="true" valueHelpOnly="true"
						valueHelpRequest="onOpenApproverList" enabled="{=${viewConfig>/editable} &amp;&amp; ${StatusId} !== '09'}"
						editable="{= ${editMRF>Apvtype} !== 'ALLOCATOR' &amp;&amp; ${editMRF>Apvtype} !== 'PROCESSOR' &amp;&amp; ${editMRF>Status} === '' }">
						<customData>
							<core:CustomData key="searchfield_maxlength" value="10"/>
						</customData>
					</Input>
					<ObjectIdentifier text="{editMRF>Name}"/>
					<ObjectIdentifier text="{editMRF>Sapid}"/>
					<ObjectStatus state="{path: 'editMRF>Status', formatter: '.formatter.formatApproverStatus'}"
						text="{= ${editMRF>Status} === '' ? ${i18n>Pending} : ${editMRF>Status}}" visible="{=${StatusId} !== '01' &amp;&amp; ${StatusId} !== '11'}"/>
					<!-- Enabled only if 'edit request' is clicked and status id not equal to 09 / Returned -->
					<Button icon="sap-icon://sys-cancel"
						enabled="{=${editMRF>Editable} &amp;&amp; ${viewConfig>/editable} &amp;&amp; ${editMRF>Status} === '' &amp;&amp; ${StatusId} !== '09'}"
						press="onDeleteApv"/>
				</cells>
			</ColumnListItem>
		</items>
	</Table>
</core:FragmentDefinition>