<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:u="sap.ui.unified">
	<List id="idAttachmentList" delete="onFileDeleted" mode="Delete" headerText="Products" items="{createMRF>/NavTo_MRFHeader_Attachment}"
		class="sapUiSmallMarginBottom">
		<headerToolbar>
			<OverflowToolbar>
				<Text text="{i18n>attachmentTxt}"/>
				<ToolbarSpacer/>
				<u:FileUploader enabled="{=${createMRF>/NavTo_MRFHeader_Attachment}.length &lt;5}" icon="sap-icon://upload" typeMissmatch="onTypeMissmatch"
					fileType="xlsx,xls,doc,docx,png,pdf,jpg,jpeg,zip" buttonOnly="true" change="onFileSelect" fileSizeExceed="onFileSizeExceed" maximumFileSize="5"
					multiple="false" iconOnly="false" sameFilenameAllowed="true" buttonText="{i18n>uploadFile}"></u:FileUploader>
			</OverflowToolbar>
		</headerToolbar>
		<items>
			<CustomListItem>
				<HBox>
					<core:Icon size="2rem" src="{createMRF>Icon}" class="sapMUCItemIcon sapUiSmallMarginBegin sapUiSmallMarginTopBottom"/>
					<VBox class="sapUiSmallMarginBegin sapUiSmallMarginTopBottom">
						<Title text="{createMRF>FileName}"/>
						<Label text="{i18n>fileSize} {path: 'createMRF>FileSize'}"/>
					</VBox>
				</HBox>
			</CustomListItem>
		</items>
	</List>
</core:FragmentDefinition>